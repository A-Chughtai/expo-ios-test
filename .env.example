# Base URL for the ATOM API. Defaults to the dev server found in
# docs/Atom Mobile App.postman_collection.json if unset.
EXPO_PUBLIC_API_URL=https://dev-atom-api.tw1.com/v1

# Quick sign-in picker (docs/atom-mobile-approvals-design-brief.md §2, Tier 1 roles).
# JSON array of demo accounts. Provide real VPC/VPF/President test credentials here —
# none exist in docs/, so the picker renders empty until this is set.
# Example:
# EXPO_PUBLIC_DEMO_ACCOUNTS_JSON=[{"role":"VPC","label":"VP Business Development","username":"YOUR_USERNAME","password":"YOUR_PASSWORD"},{"role":"VPF","label":"EVP Finance","username":"YOUR_USERNAME","password":"YOUR_PASSWORD"},{"role":"PRESIDENT","label":"President","username":"YOUR_USERNAME","password":"YOUR_PASSWORD"}]
EXPO_PUBLIC_DEMO_ACCOUNTS_JSON=
